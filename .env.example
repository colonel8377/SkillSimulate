# Environment variables for CADP
CADP_OPENAI_API_KEY=your-api-key-here
CADP_OPENAI_BASE_URL=https://api.openai.com/v1

# Multi-endpoint pool (optional — unset = legacy single-client path).
# Format: CADP_ENDPOINTS_<MODEL_NAME_UPPER>='[{"base_url": "...", "api_key": "...", "model": "..."}]'
#   model    = per-endpoint model-id override (empty = use models.yaml parent)
#   base_url = per-endpoint override (empty = use CADP_OPENAI_BASE_URL)
#   api_key  = per-endpoint override (empty = use CADP_OPENAI_API_KEY)
# After 10 consecutive failures an endpoint is marked dead and skipped.
# Override threshold: CADP_ENDPOINT_FAILURE_THRESHOLD=<int>
# All dead → experiment halts with AllEndpointsExhausted.
#
# Example (fill in your own keys):
# CADP_ENDPOINTS_DEEPSEEK_V4_FLASH='[
#   {"base_url": "https://api.deepseek.com", "api_key": "sk-xxx", "model": "deepseek-chat"},
#   {"base_url": "https://proxy.example.com/v1", "api_key": "sk-yyy"}
# ]'
# CADP_ENDPOINTS_DEEPSEEK_V4_PRO='[
#   {"base_url": "https://api.deepseek.com", "api_key": "sk-zzz", "model": "deepseek-reasoner"}
# ]'
# CADP_ENDPOINTS_MINIMAX_M3='[
#   {"base_url": "https://api.minimax.io/v1", "api_key": "sk-xxx", "model": "MiniMax-M3"}
# ]'
